# ──────────────────────────────────────────────────────────────
# PULSO — Variables de entorno
# Copia este archivo a .env y rellena los valores marcados.
# El archivo .env está en .gitignore y NO se commitea.
# ──────────────────────────────────────────────────────────────

# Servidor HTTP (deja 0.0.0.0 para acceso desde tu LAN)
# 4040 por defecto porque 4000 lo usa code-server en este servidor.
PORT=4040
HOST=0.0.0.0

# Directorio donde se guardan los patches del usuario
DATA_DIR=./data

# ─── GitHub (push por SSH; no se necesita token si SSH ya está configurado) ───
GITHUB_USER=felipesuarez-dev
GITHUB_REPO=pulso-music
# Token sólo necesario si quieres CREAR el repo via API. Si ya existe en
# github.com/$GITHUB_USER/$GITHUB_REPO, déjalo vacío y se usa SSH directo.
GITHUB_TOKEN=

# ─── Gitea (servidor local) ───────────────────────────────────
GITEA_URL=http://192.168.1.2:3020
GITEA_USER=
GITEA_REPO=pulso
# Token de aplicación (Settings → Applications → Generate New Token,
# scopes: write:repository, write:user). Necesario sí o sí (no hay SSH habilitado en este Gitea).
GITEA_TOKEN=
