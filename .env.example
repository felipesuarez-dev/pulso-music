# ──────────────────────────────────────────────────────────────
# PULSO — Variables de entorno
# Copia este archivo a .env y rellena los valores marcados.
# El archivo .env está en .gitignore y NO se commitea.
# ──────────────────────────────────────────────────────────────

# Servidor HTTP (deja 0.0.0.0 para acceso desde tu LAN)
PORT=4000
HOST=0.0.0.0

# Directorio donde se guardan los patches del usuario
DATA_DIR=./data

# ─── Gitea (servidor local) ───────────────────────────────────
# URL del servidor Gitea
GITEA_URL=http://192.168.1.2:3020
# Tu usuario de Gitea
GITEA_USER=
# Token de aplicación (crear en: http://192.168.1.2:3020/user/settings/applications)
#   → "Generate New Token" con scopes: write:repository, write:user
GITEA_TOKEN=

# ─── GitHub ───────────────────────────────────────────────────
# Tu usuario de GitHub (por defecto: felipesuarez-dev)
GITHUB_USER=felipesuarez-dev
# Personal Access Token clásico con scope "repo"
#   → https://github.com/settings/tokens/new?scopes=repo&description=pulso
GITHUB_TOKEN=
